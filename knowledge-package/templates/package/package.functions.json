{
  "name": "@your-project/functions",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:firebase-admin --external:firebase-functions --format=cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "logs": "firebase functions:log",
    "test": "jest --runInBand",
    "test:services": "jest __tests__/services --runInBand",
    "test:rules": "jest __tests__/rules",
    "test:ci": "firebase emulators:exec --only firestore,auth --project demo-your-project-test \"jest --runInBand\"",
    "seed": "tsx src/scripts/seed.ts",
    "set-role": "node scripts/setRole.mjs"
  },
  "dependencies": {
    "@your-project/shared": "workspace:*",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.0",
    "@types/jest": "^29.5.0",
    "esbuild": "^0.28.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": "22"
  }
}
