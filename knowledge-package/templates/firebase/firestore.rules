rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check user role (custom claim)
    function hasRole(role) {
      return isAuthenticated() && 
             request.auth.token.role == role;
    }

    // Helper: validate material data
    function isValidMaterialData() {
      return request.resource.data.quantity is number &&
             request.resource.data.quantity >= 0 &&
             request.resource.data.reorder_point is number &&
             request.resource.data.reorder_point >= 0 &&
             request.resource.data.cost_per_unit is number &&
             request.resource.data.cost_per_unit >= 0;
    }

    // Helper: validate stock transaction data
    function isValidStockTransaction() {
      return request.resource.data.type in ['in', 'out', 'adjust'] &&
             request.resource.data.quantity is number &&
             request.resource.data.quantity > 0 &&
             request.resource.data.material_id is string &&
             request.resource.data.material_id != '' &&
             request.resource.data.created_by == request.auth.uid;
    }

    // Helper: validate adjust transaction has reason
    function isAdjustWithReason() {
      return request.resource.data.type == 'adjust' &&
             request.resource.data.reason is string &&
             request.resource.data.reason != '';
    }

    // Helper: validate stock-in has supplier_ref
    function isInWithSupplierRef() {
      return request.resource.data.type == 'in' &&
             request.resource.data.supplier_ref is string &&
             request.resource.data.supplier_ref != '';
    }

    // Materials collection
    match /materials/{materialId} {
      allow read: if isAuthenticated();
      
      allow create: if (hasRole('admin') || hasRole('manager')) &&
                      isValidMaterialData();
      
      allow update: if (hasRole('admin') || hasRole('manager')) &&
                      isValidMaterialData();
      
      allow delete: if hasRole('admin');
    }

    // Stock transactions collection (append-only audit trail)
    match /stock_transactions/{transactionId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() &&
                      isValidStockTransaction() &&
                      (request.resource.data.type == 'adjust' ? isAdjustWithReason() : true) &&
                      (request.resource.data.type == 'in' ? isInWithSupplierRef() : true);
      
      // Immutable - never allow update/delete
      allow update, delete: if false;
    }

    // BOM collection
    match /bom/{bomId} {
      allow read: if isAuthenticated();
      
      allow create: if (hasRole('admin') || hasRole('manager')) &&
                      request.resource.data.items is list &&
                      request.resource.data.items.size() > 0;
      
      allow update: if (hasRole('admin') || hasRole('manager'));
      
      allow delete: if hasRole('admin');
    }

    // Default deny for any unmatched path
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
