rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userExists() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return userExists() && userDoc().data.role == "admin" && userDoc().data.disabled != true;
    }
    function isActiveUser() {
      return userExists() && userDoc().data.disabled != true;
    }

    // Users collection
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      // Self-create on invite accept (creating own profile doc)
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Invites collection
    match /invites/{inviteId} {
      // Anyone can query invites by token (token itself is the secret)
      allow read: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      // Update: admin full, or user accepting invite (limited)
      allow update: if isAdmin()
        || (isAuth()
            && resource.data.status == "pending"
            && request.resource.data.status == "accepted"
            && request.resource.data.acceptedBy == request.auth.uid
            && request.resource.data.email == resource.data.email
            && request.resource.data.token == resource.data.token);
    }

    // Orders — require active user
    match /orders/{orderId} {
      allow read, write: if isActiveUser();
    }

    // Customers — require active user
    match /customers/{customerId} {
      allow read, write: if isActiveUser();
    }

    // Legacy orderItems (kept for backward compat)
    match /orderItems/{itemId} {
      allow read, write: if isActiveUser();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
