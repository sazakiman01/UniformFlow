rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userExists() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isActiveUser() {
      return userExists() && userDoc().data.disabled != true;
    }
    function role() {
      return userDoc().data.role;
    }
    function isOwner()     { return isActiveUser() && (role() == 'owner' || role() == 'admin'); }
    function isAccountant(){ return isActiveUser() && (role() == 'accountant' || role() == 'owner' || role() == 'admin'); }
    function isStaff()     { return isActiveUser() && role() != 'viewer'; }
    function isViewer()    { return isActiveUser(); }

    // Backward-compat alias
    function isAdmin() { return isOwner(); }

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isOwner());
      allow create: if isAuth() && request.auth.uid == uid;
      allow update, delete: if isOwner();
    }

    // ── Invites ──────────────────────────────────────────────────────────
    match /invites/{inviteId} {
      allow read: if true;
      allow create, delete: if isOwner();
      allow update: if isOwner()
        || (isAuth()
            && resource.data.status == "pending"
            && request.resource.data.status == "accepted"
            && request.resource.data.acceptedBy == request.auth.uid
            && request.resource.data.email == resource.data.email
            && request.resource.data.token == resource.data.token);
    }

    // ── Operations (orders, customers, production, inventory) ────────────
    match /orders/{orderId}      { allow read: if isViewer(); allow write: if isStaff(); }
    match /customers/{customerId}{ allow read: if isViewer(); allow write: if isStaff(); }
    match /orderItems/{itemId}   { allow read: if isViewer(); allow write: if isStaff(); }
    match /production/{prodId}   { allow read: if isViewer(); allow write: if isStaff(); }
    match /tailors/{tailorId}    { allow read: if isViewer(); allow write: if isStaff(); }
    match /inventory/{itemId}    { allow read: if isViewer(); allow write: if isStaff(); }
    match /notifications/{notifId}{ allow read: if isViewer(); allow write: if isStaff(); }

    // ── Company Profile (singleton) ──────────────────────────────────────
    match /companyProfile/{docId} {
      allow read: if isActiveUser();
      allow write: if isOwner();
    }

    // ── Document Counters ────────────────────────────────────────────────
    // Only readable by accountants+; writes happen via transactions only.
    match /documentCounters/{counterId} {
      allow read: if isAccountant();
      allow write: if isAccountant();
    }

    // ── Quotations ───────────────────────────────────────────────────────
    match /quotations/{quoteId} {
      allow read: if isViewer();
      allow create, update: if isAccountant();
      allow delete: if isOwner();
    }

    // ── Invoices (tax-bound — limited deletion) ──────────────────────────
    match /invoices/{invoiceId} {
      allow read: if isViewer();
      allow create: if isAccountant();
      // Update allowed for accountant; cancellation must be done in app logic
      allow update: if isAccountant();
      // No deletion — must use cancellation + credit note workflow
      allow delete: if false;
    }

    match /invoicePayments/{paymentId} {
      allow read: if isViewer();
      allow create: if isAccountant();
      allow update: if isAccountant();
      allow delete: if isOwner();
    }

    // ── Credit Notes (immutable after issue) ─────────────────────────────
    match /creditNotes/{cnId} {
      allow read: if isViewer();
      allow create: if isAccountant();
      allow update: if isAccountant() && resource.data.status == 'draft';
      allow delete: if false;
    }

    // ── Delivery Notes ───────────────────────────────────────────────────
    match /deliveryNotes/{dnId} {
      allow read: if isViewer();
      allow write: if isStaff();
    }

    // ── Expenses ─────────────────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow read: if isViewer();
      allow create, update: if isAccountant();
      allow delete: if isOwner();
    }

    // ── Receipts (ใบเสร็จรับเงิน — ออกแล้วแก้ไม่ได้) ─────────────────────
    match /receipts/{receiptId} {
      allow read: if isViewer();
      allow create: if isAccountant();
      allow update, delete: if false;
    }

    // ── Billing Notes (ใบวางบิล — แก้ status ได้) ────────────────────────
    match /billingNotes/{noteId} {
      allow read: if isViewer();
      allow create, update: if isAccountant();
      allow delete: if isOwner();
    }

    // ── WHT Certificates (immutable after issue) ─────────────────────────
    match /whtCertificates/{whtId} {
      allow read: if isViewer();
      allow create: if isAccountant();
      allow update, delete: if false;
    }

    // ── Audit logs (write-only via app, read by accountants+) ────────────
    match /auditLogs/{logId} {
      allow read: if isAccountant();
      allow create: if isActiveUser();
      allow update, delete: if false;
    }

    // ── Default deny ─────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
